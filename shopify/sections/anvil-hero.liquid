{{ 'anvil-hero.css' | asset_url | stylesheet_tag }}

<!-- ─── CUSTOM CURSOR ─────────────────────────────────────────── -->
<div class="anvil-cursor" id="anvil-cursor"></div>

<!-- ─── NAV ──────────────────────────────────────────────────── -->
<nav class="anvil-nav" id="anvil-nav">
  <ul class="anvil-nav__links">
    {% if section.settings.nav_link_1_label != blank %}
      <li><a href="{{ section.settings.nav_link_1_url }}">{{ section.settings.nav_link_1_label }}</a></li>
    {% endif %}
    {% if section.settings.nav_link_2_label != blank %}
      <li><a href="{{ section.settings.nav_link_2_url }}">{{ section.settings.nav_link_2_label }}</a></li>
    {% endif %}
  </ul>

  <a href="{{ routes.root_url }}" class="anvil-nav__logo">
    {{ section.settings.brand_name | default: 'ANVIL' }}
  </a>

  <div class="anvil-nav__right">
    <a href="/search" class="anvil-nav__action">Search</a>
    <a href="{{ routes.account_url }}" class="anvil-nav__action">Account</a>
    <a href="{{ routes.cart_url }}" class="anvil-nav__action">
      Cart
      {%- if cart.item_count > 0 -%}
        <span class="anvil-nav__cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>
</nav>

<!-- ─── HERO BORDER LINES ─────────────────────────────────────── -->
<div class="anvil-border-left"  id="anvil-border-left"></div>
<div class="anvil-border-right" id="anvil-border-right"></div>

<!-- ─── HERO SIDEBAR TEXT ────────────────────────────────────── -->
<div class="anvil-sidebar-text" id="anvil-sidebar-text">
  <span class="anvil-sidebar__label">{{ section.settings.collection_label | default: 'Collection 2026' }}</span>
  <p class="anvil-sidebar__tagline">{{ section.settings.tagline | default: 'Homeware and functional objects, wood and steel, designed and handcrafted in the UK.' }}</p>
</div>

<!-- ─── HERO FRAME ────────────────────────────────────────────── -->
<div class="anvil-hero-frame" id="anvil-hero-frame">
  <div class="anvil-hero-frame__left"></div>
  <div class="anvil-hero-frame__right">
    <div class="anvil-scroll-hint">
      <div class="anvil-scroll-arrow"></div>
      <span>Scroll</span>
    </div>
  </div>
</div>

<!-- ─── ANIMATION WRAPPER ─────────────────────────────────────── -->
<div class="anvil-scroll-wrapper" id="anvil-scroll-wrapper">
  <div class="anvil-container" id="anvil-container">

    <h2 class="anvil-waka">{{ section.settings.brand_name | default: 'ANVIL' }}</h2>

    <div class="anvil-grid__animation-wrapper">
      <div class="anvil-grid">

        <!-- Left image (large) -->
        <a href="{{ section.settings.featured_link | default: routes.collections_url }}"
           class="anvil-grid__item anvil-grid__item--featured"
           aria-label="{{ section.settings.featured_alt | default: 'Featured product' }}">
          <div class="anvil-grid__item-image">
            <div class="anvil-responsive-image" style="background-color: {{ section.settings.featured_bg | default: '#8c837b' }};">
              {%- if section.settings.featured_image -%}
                <img
                  src="{{ section.settings.featured_image | image_url: width: 1600 }}"
                  srcset="
                    {{ section.settings.featured_image | image_url: width: 800 }} 800w,
                    {{ section.settings.featured_image | image_url: width: 1200 }} 1200w,
                    {{ section.settings.featured_image | image_url: width: 1600 }} 1600w"
                  alt="{{ section.settings.featured_image.alt | default: section.settings.featured_alt }}"
                  loading="eager"
                  width="{{ section.settings.featured_image.width }}"
                  height="{{ section.settings.featured_image.height }}"
                >
              {%- else -%}
                <div class="anvil-img-placeholder" style="background: #8c837b;"></div>
              {%- endif -%}
            </div>
          </div>
        </a>

        <!-- Right image (single panel with CTA) -->
        <div class="anvil-grid__item anvil-grid__item--side">
          <div class="anvil-grid__item-panel">
            <div class="anvil-responsive-image" style="background-color: {{ section.settings.panel_bg | default: '#8c837b' }};">
              {%- if section.settings.panel_image -%}
                <img
                  src="{{ section.settings.panel_image | image_url: width: 800 }}"
                  alt="{{ section.settings.panel_image.alt | default: 'Collection' }}"
                  loading="eager"
                  width="{{ section.settings.panel_image.width }}"
                  height="{{ section.settings.panel_image.height }}"
                >
              {%- else -%}
                <div class="anvil-img-placeholder" style="background: #7a7268;"></div>
              {%- endif -%}
            </div>
            <div class="anvil-grid__cta-overlay">
              <span class="anvil-grid__cta-label">{{ section.settings.cta_label | default: 'Our Collection' }}</span>
              <h3 class="anvil-grid__cta-heading">{{ section.settings.cta_heading | default: 'Visit our shop to see our wares.' }}</h3>
              <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="anvil-grid__cta-btn">
                {{ section.settings.cta_button | default: 'Explore the collection →' }}
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>

    <h2 class="anvil-waka anvil-waka--bottom">{{ section.settings.brand_name | default: 'ANVIL' }}</h2>

  </div>
</div>

<button class="anvil-replay-btn" id="anvil-replay-btn" aria-label="Replay animation">&#8635; Replay</button>

<!-- ─── MARQUEE ────────────────────────────────────────────────── -->
<div class="anvil-marquee-strip" aria-hidden="true" id="anvil-marquee">
  <div class="anvil-marquee-track">
    {%- assign marquee_items = section.settings.marquee_text | split: ',' -%}
    {%- if marquee_items.size < 2 -%}
      {%- assign marquee_items = 'Handcrafted Homeware,Functional Objects,Made by Hand,Limited Edition' | split: ',' -%}
    {%- endif -%}
    {%- for item in marquee_items -%}
      <span class="anvil-marquee-item">{{ item | strip }}</span>
    {%- endfor -%}
    {%- for item in marquee_items -%}
      <span class="anvil-marquee-item">{{ item | strip }}</span>
    {%- endfor -%}
  </div>
</div>

<!-- ─── INIT ──────────────────────────────────────────────────── -->
<script src="{{ 'anvil-hero.js' | asset_url }}"></script>
<script>
  /* GSAP is loaded at end of <body> in theme.liquid.
     Wait for window.load so it is guaranteed available. */
  window.addEventListener('load', function () {
    if (typeof anvilHeroInit === 'function') {
      anvilHeroInit();
    }
  });
</script>

{% schema %}
{
  "name": "ANVIL Hero",
  "tag": "div",
  "class": "anvil-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "ANVIL"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "nav_link_1_label",
      "label": "Nav link 1 label",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "nav_link_1_url",
      "label": "Nav link 1 URL"
    },
    {
      "type": "text",
      "id": "nav_link_2_label",
      "label": "Nav link 2 label",
      "default": "Catalogue"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Nav link 2 URL"
    },
    {
      "type": "header",
      "content": "Hero sidebar"
    },
    {
      "type": "text",
      "id": "collection_label",
      "label": "Collection label",
      "default": "Collection 2026"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Homeware and functional objects, wood and steel, designed and handcrafted in the UK."
    },
    {
      "type": "header",
      "content": "Left image"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Left image"
    },
    {
      "type": "text",
      "id": "featured_alt",
      "label": "Left image alt text",
      "default": "Featured product"
    },
    {
      "type": "color",
      "id": "featured_bg",
      "label": "Left image placeholder colour",
      "default": "#8c837b"
    },
    {
      "type": "url",
      "id": "featured_link",
      "label": "Left image link"
    },
    {
      "type": "header",
      "content": "Right image"
    },
    {
      "type": "image_picker",
      "id": "panel_image",
      "label": "Right image"
    },
    {
      "type": "color",
      "id": "panel_bg",
      "label": "Right image placeholder colour",
      "default": "#8c837b"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA eyebrow label",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Visit our shop to see our wares."
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA button text",
      "default": "Explore the collection →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee items (comma-separated)",
      "default": "Handcrafted Homeware,Functional Objects,Made by Hand,Limited Edition"
    }
  ],
  "presets": [
    {
      "name": "ANVIL Hero"
    }
  ]
}
{% endschema %}
